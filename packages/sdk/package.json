{
  "name": "keydrop",
  "version": "1.1.0",
  "description": "Turn your .env into one deployable key - Runtime SDK",
  "type": "module",
  "main": "./src/init.cjs",
  "types": "./src/init.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./src/init.js",
      "require": "./src/init.cjs",
      "types": "./src/init.d.ts",
      "default": "./src/init.js"
    }
  },
  "keywords": [
    "env",
    "environment",
    "secrets",
    "dotenv",
    "config",
    "keydrop"
  ],
  "author": "Your Name",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/devansh-jagtap/keydrop.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/devansh-jagtap/keydrop/issues"
  },
  "homepage": "https://github.com/devansh-jagtap/keydrop#readme",
  "files": [
    "src/init.js",
    "src/init.cjs",
    "src/init.d.ts",
    "README.md"
  ],
  "dependencies": {
    "axios": "^1.6.0"
  }
}
