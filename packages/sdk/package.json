{
  "name": "keydrop",
  "version": "1.0.6",
  "description": "Turn your .env into one deployable key",
  "type": "module",
  "main": "./src/init.cjs",
  "types": "./src/init.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./src/init.js",
      "require": "./src/init.cjs",
      "types": "./src/init.d.ts",
      "default": "./src/init.js"
    }
  },
  "dependencies": {
    "axios": "^1.6.0"
  }
}