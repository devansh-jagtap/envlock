generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String @id @default(cuid())
  email       String @unique
  password    String
  projects   Project[]
  createdAt  DateTime @default(now())
}
model Project {
  id            String @id @default(cuid())
  projectKey    String @unique
  encryptedData String
  name          String?
  userId        String?
  user          User? @relation(fields: [userId], references: [id])
}